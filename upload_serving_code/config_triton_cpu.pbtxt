# Triton CPU model config
# Difference from triton_gpu: KIND_CPU instead of KIND_GPU
name: "song_recommender"
platform: "onnxruntime_onnx"
max_batch_size: 32

input [
  {
    name: "user_embedding"
    data_type: TYPE_FP32
    dims: [ 64 ]
  }
]

output [
  {
    name: "scores"
    data_type: TYPE_FP32
    dims: [ 10000 ]
  }
]

# Run on CPU
instance_group [
  {
    count: 1
    kind: KIND_CPU
  }
]

# Dynamic batching — groups requests arriving within 5ms into one batch
dynamic_batching {
  max_queue_delay_microseconds: 5000
}
